<main>
  <div class="lobby-header">
    <h1>Sorry!</h1>
    <div class="lobby-status">
      <span id="sse-status" class="sse-status sse-status--disconnected">disconnected</span>
      <span id="lobby-message"></span>
    </div>
  </div>

  <div class="lobby-layout">
    <aside>
      <div class="panel">
        <div class="panel-header">
          <h2>Games</h2>
          <button id="create-game-btn" class="btn-create" type="button">+ New</button>
        </div>
        <div id="game-list" class="game-list"></div>
      </div>
    </aside>

    <section>
      <div class="panel">
        <div id="game-detail" class="game-detail">
          <div class="game-detail-empty">Select or create a game to get started.</div>
        </div>
      </div>
    </section>
  </div>

  <script defer type="module" src="/js/lobby.js"></script>
</main>
